<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <%- include('../partials/seo', {
        title: 'Cadastro de Empresa - Dados do Responsável',
        description: 'Cadastre o responsável pela empresa na plataforma. Informe nome, cargo, e-mail e telefone comercial.',
        prev: '/cadastro-empresa',
        next: '/cadastro-empresa3'
      }) %>

  <link rel="stylesheet" href="/css/cadastro-comum.css">
  <link rel="stylesheet" href="/css/validation.css">
  <link rel="stylesheet" href="/css/cadastro-empresa2.css">
</head>

<body>

<header>
  <%- include('../partials/menu') %>
  <h1 class="cadastro">Dados do Responsável</h1>
</header>

<main class="cad-container">

  <section class="step-progress" aria-label="Progresso do cadastro">

    <ol class="steps">

      <li class="step completed" aria-current="step">
        <span>1</span>
      </li>

      <li class="step-line completed" aria-hidden="true"></li>

      <li class="step active">
        <span>2</span>
      </li>

      <li class="step-line" aria-hidden="true"></li>

      <li class="step">
        <span>3</span>
      </li>

    </ol>

  </section>


  <section class="form-section">

    <header>
      <h2>Informe os dados do responsável pela empresa</h2>
    </header>

    <% if (locals.errors && errors.length > 0) { %>
      <article class="general-error" role="alert">
        <% errors.forEach(error => { %>
          <p><%= error.msg %></p>
        <% }) %>
      </article>
    <% } %>


    <form id="empresaForm2" class="cad-form" method="POST" action="/cadastro-empresa2">

      <fieldset>

        <legend class="visually-hidden">
          Dados do responsável
        </legend>


        <section class="form-group">

          <label for="nome">Nome completo do responsável</label>

          <input
            type="text"
            id="nome"
            name="nome"
            placeholder="Nome completo do responsável"
            value="<%= locals.form ? form.nome || '' : '' %>"
            required>

          <span class="field-error" aria-live="polite">
            <%= locals.errors && errors.find(e => e.param === 'nome') ? errors.find(e => e.param === 'nome').msg : '' %>
          </span>

        </section>


        <section class="form-group">

          <label for="cargo">Cargo na empresa</label>

          <input
            type="text"
            id="cargo"
            name="cargo"
            placeholder="Cargo na empresa"
            value="<%= locals.form ? form.cargo || '' : '' %>"
            required>

          <span class="field-error" aria-live="polite">
            <%= locals.errors && errors.find(e => e.param === 'cargo') ? errors.find(e => e.param === 'cargo').msg : '' %>
          </span>

        </section>


        <section class="form-group">

          <label for="email">Email institucional</label>

          <input
            type="email"
            id="email"
            name="email"
            placeholder="Email institucional"
            value="<%= locals.form ? form.email || '' : '' %>"
            required>

          <span class="field-error" aria-live="polite">
            <%= locals.errors && errors.find(e => e.param === 'email') ? errors.find(e => e.param === 'email').msg : '' %>
          </span>

        </section>


        <section class="form-group">

          <label for="telefone">Telefone comercial</label>

          <input
            type="tel"
            id="telefone"
            name="telefone"
            placeholder="Telefone comercial"
            value="<%= locals.form ? form.telefone || '' : '' %>"
            required>

          <span class="field-error" aria-live="polite">
            <%= locals.errors && errors.find(e => e.param === 'telefone') ? errors.find(e => e.param === 'telefone').msg : '' %>
          </span>

        </section>


        <section class="form-group">

          <label for="password">Criar senha</label>

          <input
            type="password"
            id="password"
            name="password"
            placeholder="Criar senha"
            required>

          <span class="field-error" aria-live="polite">
            <%= locals.errors && errors.find(e => e.param === 'password') ? errors.find(e => e.param === 'password').msg : '' %>
          </span>

        </section>


        <section class="form-group">

          <label for="confirmPassword">Confirmar senha</label>

          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            placeholder="Confirmar senha"
            required>

          <span class="field-error" aria-live="polite">
            <%= locals.errors && errors.find(e => e.param === 'confirmPassword') ? errors.find(e => e.param === 'confirmPassword').msg : '' %>
          </span>

        </section>

      </fieldset>

    </form>

  </section>


  <section class="actions-section">

    <button id="btnAnterior" class="btn-secondary">
      Anterior
    </button>

    <button id="btnProximo" class="btn-primary">
      Próximo
    </button>

  </section>

</main>


<footer></footer>


<script src="/js/validation.js"></script>
<script src="/js/input-masks.js"></script>

<script>

document.addEventListener('DOMContentLoaded', function(){

  const empresaValidator2 = initFormValidation('empresaForm2');

  document.getElementById('btnAnterior')
  .addEventListener('click', function(){

    window.location.href = '/cadastro-empresa';

  });

  document.getElementById('btnProximo')
  .addEventListener('click', function(e){

    e.preventDefault();

    if(empresaValidator2.validateForm()){

      window.location.href = '/cadastro-empresa3';

    }

  });

  function digits(value){

    return (value || '').replace(/\D/g, '');

  }

  const form = document.getElementById('empresaForm2');

  if(form){

    form.addEventListener('submit', function(){

      const telefoneInput = form.querySelector('#telefone');

      if(telefoneInput){

        telefoneInput.value = digits(telefoneInput.value);

      }

    }, { capture:true });

  }

});

</script>

</body>
</html>