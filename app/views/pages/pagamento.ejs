<!DOCTYPE html>
<html lang="pt-BR">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Pagamento da Vaga | Empresa</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
<link href="/css/pagamento.css" rel="stylesheet">

</head>

<body>

<header>
<%- include('../partials/menuempresa') %>
</header>


<main class="main-wrapper">

<article class="container">

<header class="page-header">
<h1 class="page-title">
Pagamento da Taxa de Publicação
</h1>
</header>


<section class="form-stepper-wrapper">

<nav class="form-stepper-container">

<section class="stepper-item active">
<figure class="stepper-circle">1</figure>
<p class="stepper-label">Informações da vaga</p>
</section>

<hr class="stepper-line">

<section class="stepper-item active">
<figure class="stepper-circle">2</figure>
<p class="stepper-label">Pagamento da taxa de publicação</p>
</section>

</nav>

</section>


<section class="payment-summary">

<p>
<span>Nível da Vaga:</span>
<span id="summary-nivel"></span>
</p>

<p class="total">
<span>Valor Total:</span>
<span id="summary-valor">R$ 0,00</span>
</p>

</section>


<form class="payment-options">

<header>
<h2>Selecione uma forma de pagamento</h2>
</header>


<fieldset class="payment-option" id="option-pix">

<input type="radio" id="radio-pix" name="payment-method" value="pix">

<label for="radio-pix">
PIX
</label>

<span class="icon">
<i class="fas fa-qrcode"></i>
</span>

</fieldset>


<fieldset class="payment-option" id="option-card">

<input type="radio" id="radio-card" name="payment-method" value="card">

<label for="radio-card">
Cartão de Crédito/Débito
</label>

<span class="icon">
<i class="fas fa-credit-card"></i>
</span>

</fieldset>


<fieldset class="payment-option" id="option-boleto">

<input type="radio" id="radio-boleto" name="payment-method" value="boleto">

<label for="radio-boleto">
Boleto Bancário
</label>

<span class="icon">
<i class="fas fa-barcode"></i>
</span>

</fieldset>

</form>


<nav class="button-group">

<button type="button" class="btn-action btn-back" onclick="history.back()">
Voltar
</button>

<button type="button" class="btn-action btn-confirm-payment" id="btn-confirm">
Confirmar Pagamento
</button>

</nav>


</article>

</main>


<aside id="successPopup" class="popup-container">

<article class="popup-content">

<button class="close-btn" onclick="closePopup()">
&times;
</button>

<figure class="icon-circle">
<span class="checkmark">&#10003;</span>
</figure>

<header>
<h2>Solicitação enviada com sucesso!</h2>
</header>

<p>
Seu pagamento foi confirmado.
</p>

<nav class="popup-actions">

<button class="btn-popup-primary" onclick="redirectToVagas()">
Clique aqui para voltar a tela de Vagas
</button>

<button class="btn-popup-secondary" onclick="printVagaDetails()">
Imprimir detalhes da vaga
</button>

</nav>

</article>

</aside>


<script src="/js/script.js" defer></script>

</body>
</html>