<!DOCTYPE html>
<html lang="pt-BR">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ápice</title>

<link rel="stylesheet" href="/css/hero.css">
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/footer.css">
<link rel="stylesheet" href="/css/menu.css">
<link rel="stylesheet" href="/css/content.css">
<link rel="stylesheet" href="/css/home.css">
<link rel="stylesheet" href="/css/vagas.css">
<link rel="stylesheet" href="/css/txtsec.css">
<link rel="stylesheet" href="/css/home-inline.css">

</head>


<body class="home-page">

<header>
<%- include('../partials/menu') %>
</header>


<!-- HERO -->
<section class="hero">

<article class="hero-content">

<section class="hero-content-grid">


<section class="hero-text-section">

<header class="hero-title-wrapper">

<h1 class="hero-title">
Conectando jovens talentos ao futuro.
</h1>

<p class="hero-description">
O Ápice é a plataforma que facilita a entrada de jovens no mercado de trabalho,
unindo empresas e candidatos em processos seletivos rápidos e assertivos.
</p>

<nav class="hero-cta">

<a href="/vagas" class="btnhome btnhome-primary">
Quero uma vaga
</a>

<a href="/empresa" class="btnhome btnhome-secondary">
Quero contratar
</a>

</nav>

</header>

</section>


<aside class="hero-image-section">

<figure class="hero-img-container">

<img src="/img/homeee.svg" alt="Ilustração Ápice" class="hero-img-modern">

<section class="decorative-circles">

<span class="circle circle-yellow-1"></span>
<span class="circle circle-yellow-2"></span>
<span class="circle circle-white-1"></span>
<span class="circle circle-yellow-3"></span>
<span class="circle circle-white-2"></span>

</section>

</figure>

</aside>


</section>

</article>

</section>



<main>


<header class="vagas-title-band">

<h2 class="vagas-title">
Últimas vagas postadas
</h2>

</header>



<!-- VAGAS -->
<section class="vagas-section">

<article class="carousel-container">

<section class="carousel-track">

<% if (vagas && vagas.length > 0) { %>

<% vagas.forEach((vaga) => { %>

<article class="carousel-slide">

<%- include('../partials/job-card', { vaga: vaga }) %>

</article>

<% }); %>

<% } %>

</section>


<nav class="carousel-indicators">

<span class="indicator active" data-index="0"></span>
<span class="indicator" data-index="1"></span>
<span class="indicator" data-index="2"></span>

</nav>

</article>


<footer class="btn-container-carousel">

<a href="/vagas" class="btnhome btnhome-carousel">
Ver todas as vagas
</a>

</footer>

</section>



<!-- COMO FUNCIONA -->
<section class="como-funciona-section">

<article class="container">

<h2 class="como-funciona-title">
Como funciona
</h2>


<section class="como-funciona-cards">


<article class="funciona-card">

<figure class="funciona-icon">
<img src="/img/chapeuzinho.svg" alt="Ícone para jovens" class="icone-funciona">
</figure>

<h3 class="funciona-card-title">
Para jovens
</h3>

<ul class="funciona-list">

<li><img src="/img/crie.seu.perfil.svg" alt="" class="icon-item">Crie seu perfil</li>
<li><img src="/img/encontre.vagas.svg" alt="" class="icon-item">Encontre vagas</li>
<li><img src="/img/processos.svg" alt="" class="icon-item">Participe dos processos</li>

</ul>

<p class="funciona-stats">
+2.000 jovens já conseguiram entrevistas pelo Ápice.
</p>

</article>



<article class="funciona-card">

<figure class="funciona-icon">
<img src="/img/predios.svg" alt="Ícone para empresas" class="icone-funciona">
</figure>

<h3 class="funciona-card-title">
Para empresas
</h3>

<ul class="funciona-list">

<li><img src="/img/publique.vagas.svg" alt="" class="icon-item">Publique vagas</li>
<li><img src="/img/receba.svg" alt="" class="icon-item">Receba candidatos</li>
<li><img src="/img/contrate.svg" alt="" class="icon-item">Contrate com facilidade</li>

</ul>

<p class="funciona-stats">
+100 empresas já contratam pelo Ápice
</p>

</article>

</section>

</article>

</section>



<!-- CLIENTES -->
<section class="clientes-section">

<article class="container">

<h2 class="clientes-title">
Principais clientes
</h2>

<section class="clientes-slider-container">

<article class="clientes-slider-track">

<figure class="cliente-slide"><img src="/img/coca.cola.svg" alt="Logo Coca-Cola"></figure>
<figure class="cliente-slide"><img src="/img/assai.svg" alt="Logo Assaí"></figure>
<figure class="cliente-slide"><img src="/img/atacadao.svg" alt="Logo Atacadão"></figure>
<figure class="cliente-slide"><img src="/img/carrefour.svg" alt="Logo Carrefour"></figure>
<figure class="cliente-slide"><img src="/img/eletro.svg" alt="Logo Eletros"></figure>
<figure class="cliente-slide"><img src="/img/magalu.svg" alt="Logo Magazine Luiza"></figure>
<figure class="cliente-slide"><img src="/img/renner.svg" alt="Logo Renner"></figure>
<figure class="cliente-slide"><img src="/img/vivo.svg" alt="Logo Vivo"></figure>

</article>

</section>

</article>

</section>



</main>



<footer>
<%- include('../partials/footer') %>
</footer>


<script src="/js/script.js"></script>

</body>
</html>