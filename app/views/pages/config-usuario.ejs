<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Configurações do Usuário - Ápice</title>

<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/menu.css">
<link rel="stylesheet" href="/css/footer.css">
<link rel="stylesheet" href="/css/config-usuario.css">
<link rel="stylesheet" href="/css/config-usuario-inline.css">
</head>

<body>

<header>
  <%- include('../partials/menujovem') %>
</header>

<main class="config-container">

<header class="config-header">

<button class="back-button" aria-label="Voltar">
<img src="/img/seta2.png" alt="" class="back-icon">
</button>

<h1 class="config-main-title">
Configurações do Jovem
</h1>

</header>


<section class="config-content">

<article class="config-card">

<figure class="card-icon">
<img src="/img/user.svg" alt="" class="icon">
</figure>

<section class="card-content">
<h2 class="card-title">Alterar dados do perfil</h2>
<p class="card-description">
Altere seu nome de usuário e outras informações pessoais.
</p>
</section>

<span class="card-arrow"></span>

</article>


<article class="config-card">

<figure class="card-icon">
<img src="/img/pdf.svg" alt="" class="icon">
</figure>

<section class="card-content">
<h2 class="card-title">Alterar dados da sua conta</h2>
<p class="card-description">
Atualize informações da sua conta utilizadas na plataforma Ápice.
</p>
</section>

<span class="card-arrow"></span>

</article>


<article class="config-card">

<figure class="card-icon">
<img src="/img/privacidade.svg" alt="" class="icon">
</figure>

<section class="card-content">
<h2 class="card-title">Privacidade e segurança</h2>
<p class="card-description">
Gerencie suas preferências de privacidade e comunicação.
</p>
</section>

<span class="card-arrow"></span>

</article>


<article class="config-card">

<figure class="card-icon">
<img src="/img/excluir.svg" alt="" class="icon">
</figure>

<section class="card-content">
<h2 class="card-title">Excluir conta</h2>
<p class="card-description">
Remova permanentemente sua conta da Ápice.
</p>
</section>

<span class="card-arrow"></span>

</article>

</section>

</main>

<footer>
  <%- include('../partials/footer') %>
</footer>

</body>
</html>