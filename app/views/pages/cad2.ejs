<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ápice</title>

  <link rel="stylesheet" href="/css/cadastro-comum.css">
  <link rel="stylesheet" href="/css/validation.css">
</head>

<body>

<header>
  <%- include('../partials/menu') %>
  <h1 class="cadastro">Cadastro</h1>
</header>

<main class="cad-container">

  <section class="form-section">

    <header>
      <p>Informe suas informações para o registro</p>
    </header>

    <!-- erros gerais -->
    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <article class="general-error">
        <% errors.forEach(function(error) { %>
          <p><%= error.msg %></p>
        <% }) %>
      </article>
    <% } %>

    <form id="cad2Form" class="cad-form" method="POST" action="/cad2">

      <section class="form-group">
        <input type="text" id="rg" name="rg" placeholder="RG" required>
      </section>

      <section class="form-group">
        <input type="date" id="data" name="data" placeholder="Data de nascimento" required>
      </section>

      <section class="form-group">
        <select id="sexo" name="sexo" required>
          <option value="">Selecione o sexo</option>
          <option value="masculino">Masculino</option>
          <option value="feminino">Feminino</option>
          <option value="outro">Outro</option>
        </select>
      </section>

      <section class="form-group">
        <select id="estado" name="estado" required>
          <option value="">Estado civil</option>
          <option value="solteiro">Solteiro(a)</option>
          <option value="casado">Casado(a)</option>
          <option value="divorciado">Divorciado(a)</option>
          <option value="viuvo">Viúvo(a)</option>
        </select>
      </section>

      <section class="form-group">
        <input type="text" id="endereco" name="endereco" placeholder="Endereço" required>
      </section>

      <section class="lado">

        <section class="form-group">
          <input type="text" id="cep" name="cep" placeholder="CEP" required class="cep">
        </section>

        <section class="form-group">
          <input type="text" id="complemento" name="complemento" placeholder="Complemento" class="comp">
        </section>

      </section>

    </form>

  </section>

  <section class="actions-section">
    <button form="cad2Form" type="submit" class="btn-primary">
      Próximo
    </button>
  </section>

</main>

<footer>
</footer>

<script src="/js/validation.js"></script>

<script>

document.addEventListener('DOMContentLoaded', function() {

  const cad2Validator = initFormValidation('cad2Form');

  const cepInput = document.getElementById('cep');

  if (cepInput) {

    cepInput.addEventListener('input', function() {

      let value = this.value.replace(/\D/g, '');
      value = value.replace(/(\d{5})(\d{3})/, '$1-$2');

      this.value = value;

    });

  }

});

</script>

</body>
</html>